root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.swift]
indent_size = 4

[*.{rs,go}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_size = unset

[LICENSE]
indent_size = unset

# Generated report pages and trend data
[initial-pages/**]
indent_size = unset
indent_style = unset

[latest-history/**]
insert_final_newline = unset

[Makefile]
indent_style = tab
